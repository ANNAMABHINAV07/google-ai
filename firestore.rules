rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    match /users/{userId} {
      allow get, write: if isOwner(userId);
      
      match /sessions/{sessionId} {
        allow list, get, create, update, delete: if isOwner(userId);
      }
      
      match /goals/{goalId} {
        allow list, get, create, update, delete: if isOwner(userId);
      }
      
      match /reports/{reportId} {
        allow list, get, create: if isOwner(userId);
      }
    }

    match /workspaces/{workspaceId} {
      function isValidWorkspace(data) {
        return data.name is string && data.name.size() <= 64 
               && data.ownerId == request.auth.uid;
      }
      allow get: if isSignedIn();
      allow list: if isSignedIn() && resource.data.ownerId == request.auth.uid;
      allow create: if isSignedIn() && isValidWorkspace(request.resource.data);
      allow update, delete: if isSignedIn() && resource.data.ownerId == request.auth.uid;
    }
  }
}
